<Window
    x:Class="ImmichLauncher.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Immich ランチャー (ネイティブ)">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Immich ランチャー" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock
                Text="Docker/WSL 不要のネイティブ構成。127.0.0.1 のみにバインドし、ポート解放なしで動作します。"
                Style="{StaticResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="16">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Ellipse x:Name="PgDot" Width="10" Height="10" Fill="Gray" VerticalAlignment="Center" />
                <TextBlock Text="PostgreSQL" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Ellipse x:Name="RedisDot" Width="10" Height="10" Fill="Gray" VerticalAlignment="Center" />
                <TextBlock Text="Redis" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Ellipse x:Name="ImmichDot" Width="10" Height="10" Fill="Gray" VerticalAlignment="Center" />
                <TextBlock x:Name="ImmichStateText" Text="Immich" VerticalAlignment="Center" />
            </StackPanel>
            <ProgressRing x:Name="BusyRing" IsActive="False" Width="18" Height="18" />
        </StackPanel>

        <InfoBar
            x:Name="SetupBar"
            Grid.Row="2"
            IsOpen="False"
            IsClosable="False"
            Severity="Warning"
            Title="初回インストールが必要です"
            Message="下のボタンを押すと、PostgreSQL / Redis / ffmpeg / Immich(ソースからビルド) を自動でダウンロード・構築します。合計約1GBのダウンロードと10〜30分のビルドが必要です。">
            <InfoBar.ActionButton>
                <Button x:Name="AutoSetupButton" Content="⬇ 自動セットアップを実行" Click="OnAutoSetup" />
            </InfoBar.ActionButton>
        </InfoBar>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
            <Button x:Name="StartButton" Style="{StaticResource AccentButtonStyle}" Click="OnStart">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE768;" FontSize="14" />
                    <TextBlock Text="起動" />
                </StackPanel>
            </Button>
            <Button x:Name="StopButton" Click="OnStop">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE71A;" FontSize="14" />
                    <TextBlock Text="停止" />
                </StackPanel>
            </Button>
            <Button x:Name="OpenButton" Click="OnOpenBrowser">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE774;" FontSize="14" />
                    <TextBlock Text="ブラウザで開く" />
                </StackPanel>
            </Button>
            <Button Click="OnOpenLibrary">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xEB9F;" FontSize="14" />
                    <TextBlock Text="写真フォルダ" />
                </StackPanel>
            </Button>
            <Button Click="OnOpenLogs">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE7C3;" FontSize="14" />
                    <TextBlock Text="ログフォルダ" />
                </StackPanel>
            </Button>
        </StackPanel>

        <Expander
            Grid.Row="4"
            Header="設定"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch">
            <StackPanel Spacing="16" Padding="0,8,0,0">

                <!-- 管理者アカウント -->
                <StackPanel Spacing="8">
                    <TextBlock Text="管理者アカウント" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap"
                        Text="未作成なら新規作成、既存ならパスワードをリセットし、メールアドレスも変更します(Immich 起動中に実行)。" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox x:Name="AdminEmailBox" Header="メールアドレス" PlaceholderText="you@example.com" Width="220" />
                        <PasswordBox x:Name="AdminPasswordBox" Header="パスワード" Width="180" />
                        <TextBox x:Name="AdminNameBox" Header="表示名 (任意)" PlaceholderText="Admin" Width="140" />
                    </StackPanel>
                    <Button x:Name="ApplyAccountButton" Click="OnApplyAccount" Content="アカウントを設定" />
                </StackPanel>

                <!-- 保存先の変更 -->
                <StackPanel Spacing="8">
                    <TextBlock Text="写真の保存先 (ドライブ変更)" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:Name="CurrentLibraryText" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox x:Name="NewLibraryBox" PlaceholderText="例: D:\ImmichLibrary" Width="340" />
                        <Button Click="OnPickFolder" Content="参照..." />
                        <Button x:Name="MoveLibraryButton" Click="OnMoveLibrary" Content="ここへ移動" />
                    </StackPanel>
                    <TextBlock
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap"
                        Text="写真ファイルを移動し、データベース内のパスも公式 CLI で書き換えてから自動で再起動します。" />
                </StackPanel>
            </StackPanel>
        </Expander>

        <Expander
            Grid.Row="5"
            Header="外出先からのアクセス (Tailscale) — ポート解放不要"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch">
            <StackPanel Spacing="8" Padding="0,8,0,0">
                <TextBlock
                    TextWrapping="Wrap"
                    Text="Tailscale の暗号化トンネル経由で、自分のアカウントのデバイスだけが HTTPS でアクセスできます。ルーター設定は不要で、インターネットには公開されません。" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="TsEnableButton" Click="OnTailscaleEnable" Content="外出先アクセスを有効化" />
                    <Button x:Name="TsDisableButton" Click="OnTailscaleDisable" Content="無効化" />
                    <Button x:Name="TsStatusButton" Click="OnTailscaleStatus" Content="状態確認" />
                </StackPanel>
                <TextBlock x:Name="TsUrlText" IsTextSelectionEnabled="True" FontFamily="Consolas" />
            </StackPanel>
        </Expander>

        <Border
            Grid.Row="6"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12">
            <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                <TextBlock
                    x:Name="LogText"
                    FontFamily="Consolas"
                    FontSize="12"
                    IsTextSelectionEnabled="True"
                    TextWrapping="Wrap" />
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
